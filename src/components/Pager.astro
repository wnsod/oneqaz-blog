---
// 정적 페이지네이션 내비 (Astro paginate 의 page 객체 사용).
export interface Props { page: any; lang?: 'ko' | 'en' }
const { page, lang = 'ko' } = Astro.props;
const prevLabel = lang === 'en' ? '← Prev' : '← 이전';
const nextLabel = lang === 'en' ? 'Next →' : '다음 →';
---
{page.lastPage > 1 && (
  <nav class="pager" aria-label="pagination">
    <a class={`pg ${page.url.prev ? '' : 'off'}`} href={page.url.prev || '#'} aria-disabled={!page.url.prev}>{prevLabel}</a>
    <span class="pg-count muted">{page.currentPage} / {page.lastPage}</span>
    <a class={`pg ${page.url.next ? '' : 'off'}`} href={page.url.next || '#'} aria-disabled={!page.url.next}>{nextLabel}</a>
  </nav>
)}
<style>
  .pager { display:flex; align-items:center; justify-content:center; gap:16px; margin:28px 0 8px; }
  .pg { font-size:13px; padding:7px 14px; border:1px solid var(--border); border-radius:999px; color: var(--text); transition: border-color .2s, color .2s; }
  .pg:hover { border-color: rgba(212,168,83,.5); color: var(--amber); }
  .pg.off { opacity:.35; pointer-events:none; }
  .pg-count { font-family: var(--font-mono); font-size:12px; }
</style>
