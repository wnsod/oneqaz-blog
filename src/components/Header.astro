---
const cats = [
  { href: '/track-record/', label: 'Track Record' },
  { href: '/market/', label: 'Market' },
  { href: '/spotlight/', label: 'Spotlight' },
  { href: '/journal/', label: 'Journal' },
];
const path = Astro.url.pathname;
// 영어 페이지 판정: /en/ 프리픽스(상설·목록) 또는 슬러그 -en(글).
const isPost = /^\/(journal|market|spotlight|track-record)\/20\d{2}-[^/]+\/$/.test(path);
const isEn = path === '/en/' || path.startsWith('/en/') || (isPost && /-en\/$/.test(path));
// EN 측에서는 내비도 /en/ 안에서 돌게 유지 — 영어로 들어온 독자가 영어로 계속 탐색.
const pfx = isEn ? '/en' : '';

// KO↔EN 쌍둥이 경로(빌드 타임 계산). 글은 슬러그 ±-en, 나머지는 /en/ 프리픽스.
// About(영어 단일 페이지)·tags(KO 전용)는 쌍이 없어 토글 미표시.
const EN_TWIN = [
  /^\/(\d+\/)?$/,                                          // 홈 + 페이지네이션
  /^\/(journal|market|spotlight|track-record)\/(\d+\/)?$/, // 카테고리 목록
  /^\/track-record\/all-time\/$/,
  /^\/(methodology|corrections)\/$/,
];
let altPath: string | null = null;
if (isPost) {
  altPath = isEn ? path.replace(/-en\/$/, '/') : path.replace(/\/$/, '-en/');
} else if (path.startsWith('/en/')) {
  altPath = path.replace(/^\/en/, '') || '/';
} else if (EN_TWIN.some((re) => re.test(path))) {
  altPath = '/en' + path;
}
---
<header>
  <div class="container-wide bar">
    <a href={isEn ? '/en/' : '/'} class="brand">
      <img src="/logo.png" alt="OneQAZ" width="26" height="26" />
      <span>OneQAZ</span>
    </a>
    <nav>
      {cats.map((c) => (
        <a href={pfx + c.href} class={path.startsWith(pfx + c.href) ? 'active' : ''}>{c.label}</a>
      ))}
      <a href="https://oneqaz.com" class="home">oneqaz.com &#8599;</a>
      {altPath && <a href={altPath} class="lang" hreflang={isEn ? 'ko' : 'en'}>{isEn ? '한국어' : 'EN'}</a>}
    </nav>
  </div>
</header>

<style>
  header { position: sticky; top: 0; z-index: 50; background: color-mix(in srgb, var(--bg) 88%, transparent); backdrop-filter: blur(8px); border-bottom: 1px solid var(--border); }
  .bar { display:flex; align-items:center; justify-content:space-between; gap:16px; padding-top:12px; padding-bottom:12px; }
  .brand { display:flex; align-items:center; gap:9px; font-weight:600; letter-spacing:3px; text-transform:uppercase; font-size:14px; color: var(--amber); }
  nav { display:flex; align-items:center; gap:18px; font-size:12px; letter-spacing:1.2px; text-transform:uppercase; font-weight:500; }
  nav a { color: var(--text-muted); transition: color .2s; }
  nav a:hover, nav a.active { color: var(--amber); }
  nav a.home { color: var(--text-muted); opacity:.7; }
  nav a.lang { padding: 3px 11px; border: 1px solid var(--border); border-radius: 999px; text-transform: none; letter-spacing: .5px; }
  nav a.lang:hover { border-color: var(--amber); color: var(--amber); }
  @media (max-width:560px){ nav { gap:11px; font-size:10px; } .brand span { display:none; } }
</style>
