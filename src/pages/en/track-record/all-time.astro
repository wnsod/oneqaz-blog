---
// All-time track record (EN — primary for the global audience; KO twin at /track-record/all-time/).
// Data: src/data/alltime.json — refreshed each publish cycle. Metrics single-sourced from
// MCP get_performance_metrics; curve series from the defining view (admin.v1_daily_equity).
import BaseLayout from '../../../layouts/BaseLayout.astro';
import stats from '../../../data/alltime.json';

const MK: Record<string, string> = { coin: 'Crypto', kr: 'Korea (KR)', us: 'US' };
const pf = (v: number | null) => (v === null || v === undefined ? '—' : v.toFixed(2));
const t = stats.total;
const curves: Record<string, any> = (stats as any).curves ?? {};
const months: string[] = [...new Set(Object.values(curves).flatMap((c: any) => c.monthly.map((x: any) => x.month)))].sort() as string[];

const W = 640, H = 170, P = 8;
function paths(c: any) {
  const vals = [...c.equity, ...c.benchmark.filter((v: any) => v !== null)];
  const lo = Math.min(...vals) - 1, hi = Math.max(...vals) + 1;
  const x = (i: number) => P + (i / Math.max(c.dates.length - 1, 1)) * (W - 2 * P);
  const y = (v: number) => H - P - ((v - lo) / (hi - lo)) * (H - 2 * P);
  const line = (arr: (number | null)[]) =>
    arr.map((v, i) => (v === null ? null : `${x(i).toFixed(1)},${y(v).toFixed(1)}`))
       .filter(Boolean).join(' ');
  return { eq: line(c.equity), bench: line(c.benchmark), lo: lo.toFixed(0), hi: hi.toFixed(0) };
}
const mret = (c: any, mo: string) => c.monthly.find((x: any) => x.month === mo)?.ret;
const bret = (c: any, mo: string) => c.bench_monthly.find((x: any) => x.month === mo)?.ret;
---
<BaseLayout title="All-time Track Record — OneQAZ" description={`OneQAZ all-time paper-trading record since ${stats.public_record_start}: ${t.n.toLocaleString()} closed trades, equity curves with benchmarks, MDD, Sharpe/Sortino/Calmar, monthly returns — losses included, verifiable via MCP.`} lang="en">
  <link rel="alternate" hreflang="en" href="https://blog.oneqaz.com/en/track-record/all-time/" slot="head" />
  <link rel="alternate" hreflang="ko" href="https://blog.oneqaz.com/track-record/all-time/" slot="head" />
  <link rel="alternate" hreflang="x-default" href="https://blog.oneqaz.com/en/track-record/all-time/" slot="head" />
  <article class="container post">
    <p class="eyebrow">track-record / all-time <a class="lt" href="/track-record/all-time/">한국어</a></p>
    <h1>All-time Track Record <span class="paper">paper trading</span></h1>
    <p class="muted lede">
      Everything since public publication began ({stats.public_record_start}) — aggregated from the
      same ledger as the daily journals, losses included, shown as-is.
    </p>

    <div class="counters">
      <div class="counter"><span class="num">{stats.days_operating}</span><span class="lab">days operating</span></div>
      <div class="counter"><span class="num">{t.n.toLocaleString()}</span><span class="lab">closed trades</span></div>
      <div class="counter"><span class="num">{t.win_rate}%</span><span class="lab">win rate</span></div>
      <div class="counter"><span class="num">{pf(t.profit_factor)}</span><span class="lab">profit factor</span></div>
    </div>

    <h2>Equity curves (synthetic fixed book · {stats.public_record_start} = 100)</h2>
    {Object.entries(curves).map(([m, c]: [string, any]) => {
      const p = paths(c);
      return (
        <div class="chart">
          <div class="chart-head">
            <strong>{MK[m] ?? m}</strong>
            <span class="legend"><i class="sw eq"></i>OneQAZ {c.equity[c.equity.length - 1]}</span>
            {c.bench_label && <span class="legend"><i class="sw bn"></i>{c.bench_label} {c.benchmark.filter((v: any) => v !== null).slice(-1)[0]}</span>}
            {c.bench_excluded && <span class="legend muted">benchmark withheld — data-quality issue under review</span>}
            <span class="paper-mini">paper</span>
          </div>
          <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label={`${MK[m]} equity curve (paper trading)`}>
            <text x={W - P} y="14" text-anchor="end" class="ax">{p.hi}</text>
            <text x={W - P} y={H - 2} text-anchor="end" class="ax">{p.lo}</text>
            {c.bench_label && <polyline points={p.bench} class="l-bench" />}
            <polyline points={p.eq} class="l-eq" />
          </svg>
          <p class="muted small">MDD <strong>{c.mdd.max_dd}%</strong> · current drawdown {c.mdd.current_dd}% · longest underwater {c.mdd.longest_underwater_days}d · {c.dates[0]} ~ {c.dates[c.dates.length - 1]}</p>
        </div>
      );
    })}

    <h2>Monthly returns (%)</h2>
    <table>
      <thead><tr><th>Month</th>{Object.keys(curves).map((m) => <th colspan="2">{MK[m] ?? m}</th>)}</tr>
        <tr><th></th>{Object.keys(curves).map(() => <><th class="sub">OneQAZ</th><th class="sub">benchmark</th></>)}</tr></thead>
      <tbody>
        {months.map((mo) => (
          <tr><td>{mo}</td>
            {Object.values(curves).map((c: any) => {
              const r = mret(c, mo), b = bret(c, mo);
              return (<><td class={r > 0 ? 'win' : r < 0 ? 'loss' : ''}>{r === undefined ? '—' : (r > 0 ? '+' : '') + r}</td>
                       <td class="muted">{b === undefined ? '—' : (b > 0 ? '+' : '') + b}</td></>);
            })}
          </tr>
        ))}
      </tbody>
    </table>

    <h2>Equity-curve metrics</h2>
    <table>
      <thead><tr><th>Market</th><th>Cumulative</th><th>MDD</th><th>Sharpe</th><th>Sortino</th><th>Calmar</th></tr></thead>
      <tbody>
        {Object.entries(curves).map(([m, c]: [string, any]) => (
          <tr>
            <td>{MK[m] ?? m}</td>
            <td class={c.metrics.cum_return < 0 ? 'loss' : 'win'}>{c.metrics.cum_return > 0 ? '+' : ''}{c.metrics.cum_return}%</td>
            <td class="loss">{c.mdd.max_dd}%</td>
            <td>{c.metrics.sharpe}</td><td>{c.metrics.sortino}</td><td>{c.metrics.calmar}</td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="muted small">Source: OneQAZ MCP <code>get_performance_metrics</code> — this table and an
      MCP re-query return the same values (single computation path). Sharpe/Sortino annualized at 365 days.</p>

    <h2>Trade statistics by market</h2>
    <table>
      <thead><tr><th>Market</th><th>Closed</th><th>Win rate</th><th>PF</th><th>Avg/trade</th><th>Best</th><th>Worst</th></tr></thead>
      <tbody>
        {Object.entries(stats.markets).map(([m, s]: [string, any]) => (
          <tr>
            <td>{MK[m] ?? m}</td><td>{s.n.toLocaleString()}</td><td>{s.win_rate}%</td>
            <td>{pf(s.profit_factor)}</td><td>{s.avg_pnl > 0 ? '+' : ''}{s.avg_pnl}%</td>
            <td class="win">+{s.best}%</td><td class="loss">{s.worst}%</td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="muted small">Window: {stats.public_record_start} ~ {stats.last_day} · refreshed {stats.generated_at} (recomputed every publish cycle)</p>

    <h2>The capital model — how these curves are computed</h2>
    <p>
      The paper engine trades without a real capital pool, so equity is computed with a
      <strong>synthetic fixed-book model</strong>: a 400-slot book per market, daily return =
      Σ(closed-trade P&L% × sizing multiplier) ÷ 400, compounded daily from
      {stats.public_record_start} = 100. 400 is the smallest round number such that concurrent
      exposure never exceeded 100% of the book in the public period (measured peak exposure
      323–371 slots); average utilization is 31–50%, so <strong>cash drag from idle slots is
      honestly included</strong>. Full definition: <a href="/en/methodology/">methodology</a>.
    </p>

    <h2>Boundaries — what is counted, and what is not</h2>
    <ul>
      <li><strong>Public-record period only.</strong> Only trades after {stats.public_record_start}
        (the start of contemporaneous publication) count — every trade in this period was published
        in a same-day journal and can be cross-checked after the fact. Earlier development-era ledger
        history exists but has no contemporaneous public record, so it is not part of the verified
        track record.</li>
      <li><strong>The 2026-07-08~15 data-defect window</strong> is shown post-quarantine — full
        disclosure at <a href="/en/corrections/">corrections</a>.</li>
      <li>Benchmarks: BTC (native), S&P500 (SPY proxy), KOSPI200 (KODEX200 proxy). A benchmark feed
        failing quality checks is withheld rather than shown.</li>
      <li>Everything is <strong>paper trading</strong>. If live accounts are ever added, paper and
        live records will be kept separate and never merged into one curve.</li>
    </ul>

    <h2>Verify it yourself</h2>
    <p>
      These numbers come from the same ledger as the daily journals. Connect
      <a href="https://github.com/wnsod/oneqaz-trading-mcp">OneQAZ MCP</a> to an AI and query the
      same data directly — e.g. <code>get_trade_history</code> (closed trades),
      <code>get_performance_metrics</code> (MDD, Sharpe and other curve metrics),
      <code>get_ledger_integrity</code> (daily SHA-256 hash chain — detects post-hoc edits). Each
      daily journal also links a full CSV of its window.
    </p>

    <hr />
    <p class="muted small">
      <strong>Disclaimer:</strong> OneQAZ figures are paper-trading research, not investment advice.
      Past simulated performance does not predict future real-money returns.
    </p>
  </article>
</BaseLayout>

<style>
  .post { padding: 56px 24px 80px; }
  h1 { font-size: clamp(26px, 4vw, 38px); font-weight: 700; color: var(--text); margin: 8px 0 12px; }
  h2 { font-size: 21px; font-weight: 600; margin: 40px 0 14px; color: var(--text); }
  .paper { font-size: 12px; vertical-align: middle; margin-left: 10px; padding: 3px 10px; border: 1px solid rgba(212,168,83,.45); border-radius: 999px; color: var(--amber); font-weight: 400; letter-spacing: .4px; }
  .lede { font-size: 14px; line-height: 1.8; max-width: 640px; }
  .counters { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 14px; margin: 28px 0 8px; }
  .counter { border: 1px solid var(--border); border-radius: var(--radius-md, 10px); padding: 18px 16px; text-align: center; background: var(--panel-bg); }
  .num { display: block; font-size: 26px; font-weight: 700; color: var(--amber); font-family: var(--font-mono); }
  .lab { display: block; margin-top: 6px; font-size: 12px; color: var(--text-muted); }
  .chart { border: 1px solid var(--border); border-radius: var(--radius-md, 10px); padding: 14px 14px 6px; margin: 0 0 18px; background: var(--panel-bg); }
  .chart-head { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; font-size: 13px; margin-bottom: 8px; color: var(--text); }
  .legend { display: inline-flex; align-items: center; gap: 5px; font-family: var(--font-mono); font-size: 12px; color: var(--text-muted); }
  .sw { width: 14px; height: 3px; display: inline-block; border-radius: 2px; }
  .sw.eq { background: var(--amber); } .sw.bn { background: #8a8f98; }
  .paper-mini { margin-left: auto; font-size: 10px; padding: 2px 8px; border: 1px solid rgba(212,168,83,.4); border-radius: 999px; color: var(--amber); letter-spacing: .5px; }
  svg { width: 100%; height: auto; display: block; }
  .l-eq { fill: none; stroke: var(--amber); stroke-width: 2; }
  .l-bench { fill: none; stroke: #8a8f98; stroke-width: 1.4; stroke-dasharray: 4 3; }
  .ax { font-size: 10px; fill: var(--text-muted); font-family: var(--font-mono); }
  table { width: 100%; border-collapse: collapse; font-size: 14px; margin: 0 0 10px; }
  th, td { border: 1px solid var(--border); padding: 8px 12px; text-align: left; }
  thead th { background: var(--panel-bg); color: var(--text); font-weight: 600; }
  th.sub { font-size: 11px; font-weight: 500; color: var(--text-muted); }
  .win { color: #3fb950; } .loss { color: #f85149; }
  p, li { font-size: 14px; line-height: 1.8; color: var(--text); }
  ul { margin: 0 0 16px 22px; } li { margin: 6px 0; }
  .small { font-size: 12px; }
  code { font-family: var(--font-mono); font-size: .92em; background: var(--panel-bg); padding: 2px 6px; border-radius: 4px; }
  a { color: var(--amber); }
  .lt { margin-left: 10px; font-size: 11px; padding: 2px 10px; border: 1px solid var(--border); border-radius: 999px; color: var(--text-muted); letter-spacing: .5px; }
  hr { border: 0; border-top: 1px solid var(--border); margin: 36px 0 16px; }
</style>
