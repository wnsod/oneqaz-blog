---
import '../styles/tokens.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  /** canonical path or absolute URL; defaults to current page */
  ogImage?: string;
  lang?: 'ko' | 'en';
}

const {
  title,
  description = 'OneQAZ — AI-published daily trading journals, market reads, and verified track record.',
  ogImage,
  lang = 'ko',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImg = ogImage ? new URL(ogImage, Astro.site).href : new URL('/og/default.png', Astro.site).href;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- 검색엔진 소유권 확인 -->
  <meta name="google-site-verification" content="oQldIHegNVQFRW5lzkPZMEPjp3gL66mgK7Q6yCS20Gc" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" type="application/rss+xml" title="OneQAZ" href={new URL('/rss.xml', Astro.site).href} />
  <link rel="icon" href="/logo.png" type="image/png" />
  <link rel="preconnect" href="https://fonts.bunny.net" />
  <link href="https://fonts.bunny.net/css?family=outfit:300,400,500,600,700|noto-sans-kr:300,400,500,700" rel="stylesheet" />

  <!-- Open Graph — for link previews + AI snippet extraction -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="OneQAZ" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImg} />
  <meta name="twitter:card" content="summary_large_image" />

  <slot name="head" />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
