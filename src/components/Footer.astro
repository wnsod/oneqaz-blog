const year = 2026;
---
<footer>
  <div class="container-wide inner">
    <div class="links">
      <a href="https://oneqaz.com">oneqaz.com</a>
      <a href="https://github.com/wnsod/oneqaz-trading-mcp">GitHub</a>
      <a href="/about/">About</a>
      <a href="/methodology/">방법론</a>
      <a href="/track-record/all-time/">누적 기록</a>
      <a href="/corrections/">정정 기록</a>
