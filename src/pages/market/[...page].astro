---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import Pager from '../../components/Pager.astro';

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const e = await getCollection('market', ({ data }) => !data.draft && data.lang !== 'en');
  const posts = e.map((x) => ({ ...x, _collection: 'market' }))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return paginate(posts, { pageSize: 36 });
}
const { page } = Astro.props;
const TITLE = 'Market';
const DESC = 'Daily regime reads across macro, equities, and crypto.';
---
<BaseLayout title={`${TITLE} — OneQAZ`} description={DESC}>
  <section class="head container-wide">
    <p class="eyebrow">market</p>
    <h1>{TITLE}</h1>
    <p class="muted lede">{DESC}</p>
  </section>
  <section class="feed container-wide">
    {page.data.length === 0 ? <p class="muted empty">No posts yet.</p> : <PostList posts={page.data} />}
    <Pager page={page} />
  </section>
</BaseLayout>
<style>
  .head { padding: 52px 24px 16px; }
  .head h1 { font-size: clamp(28px,4vw,40px); font-weight:700; margin:10px 0; color:var(--text); }
  .lede { max-width:560px; font-size:14px; }
  .feed { padding: 8px 24px 40px; }
  .empty { padding:32px 0; }
</style>
