---
// EN Track Record 목록 — /track-record/ 의 영어판 쌍둥이 (/en/track-record/all-time 은 정적 라우트 우선).
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostList from '../../../components/PostList.astro';
import Pager from '../../../components/Pager.astro';

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const e = await getCollection('track-record', ({ data }) => !data.draft && data.lang === 'en');
  const posts = e.map((x) => ({ ...x, _collection: 'track-record' }))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return paginate(posts, { pageSize: 36 });
}
const { page } = Astro.props;
const TITLE = 'Track Record';
const DESC = 'Verified prediction accuracy and outcome checks — the evidence behind OneQAZ.';
const koHref = new URL(Astro.url.pathname.replace(/^\/en/, ''), Astro.site).href;
const enHref = new URL(Astro.url.pathname, Astro.site).href;
---
<BaseLayout title={`${TITLE} — OneQAZ`} description={DESC} lang="en">
  <link rel="alternate" hreflang="en" href={enHref} slot="head" />
  <link rel="alternate" hreflang="ko" href={koHref} slot="head" />
  <link rel="alternate" hreflang="x-default" href={enHref} slot="head" />
  <section class="head container-wide">
    <p class="eyebrow">track-record</p>
    <h1>{TITLE}</h1>
    <p class="muted lede">{DESC} <a href="/en/track-record/all-time/">All-time record →</a></p>
  </section>
  <section class="feed container-wide">
    {page.data.length === 0 ? <p class="muted empty">No posts yet.</p> : <PostList posts={page.data} />}
    <Pager page={page} lang="en" />
  </section>
</BaseLayout>
<style>
  .head { padding: 52px 24px 16px; }
  .head h1 { font-size: clamp(28px,4vw,40px); font-weight:700; margin:10px 0; color:var(--text); }
  .lede { max-width:560px; font-size:14px; }
  .lede a { color: var(--amber); }
  .feed { padding: 8px 24px 40px; }
  .empty { padding:32px 0; }
</style>
