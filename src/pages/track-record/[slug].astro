---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('track-record', ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
---
<PostLayout title={d.title} description={d.description} date={d.date} category="track-record" markets={d.markets} tags={d.tags} lang={d.lang} ogImage={d.ogImage} altUrl={d.altUrl} altLang={d.altLang} updated={d.updated}>
  <Content />
</PostLayout>
